{
  "name": "tscubiomes",
  "version": "0.1.0",
  "description": "TypeScript Bedrock-first Minecraft seed, structure and biome toolkit.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tscubiomes": "./dist/cli.js"
  },
  "files": [
    "dist",
    "fixtures",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "pnpm run build && node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run build && node test/run-tests.mjs"
  },
  "keywords": [
    "minecraft",
    "bedrock",
    "cubiomes",
    "worldgen"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
